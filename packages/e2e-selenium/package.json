{
  "name": "@bitebuddy/e2e-selenium",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:headed": "cross-env SELENIUM_HEADLESS=false node --test tests/*.test.mjs",
    "seed": "node scripts/seed-test-accounts.mjs",
    "test:auth": "node --test tests/authenticated-smoke.test.mjs",
    "test:auth:headed": "cross-env SELENIUM_HEADLESS=false node --test tests/authenticated-smoke.test.mjs",
    "e2e:auth": "npm run seed && npm run test:auth"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.49.0",
    "cross-env": "^7.0.3",
    "dotenv": "^16.4.5",
    "selenium-webdriver": "^4.31.0"
  }
}
